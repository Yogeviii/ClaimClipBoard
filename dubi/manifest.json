{
  "manifest_version": 3,
  "name": "Claim Number Copy Button",
  "version": "1.0.2",
  "description": "Adds a clipboard button next to claim numbers in the E-nsure claims grid.",
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "scripting"
  ],
  "host_permissions": [
    "*://ds-ensure01.passportcard.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://ds-ensure01.passportcard.com/*"
      ],
      "all_frames": true,
      "match_about_blank": true,
      "run_at": "document_idle",
      "js": [
        "claimCopy.js"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Claim Copy Buttons",
    "default_popup": "popup.html"
  }
}
